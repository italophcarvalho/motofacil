<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>motoFÁCIL Brasil — Aluguel de Motos em Serra, ES</title>
<meta name="description" content="Aluguel de moto em Serra-ES sem burocracia. Saia de moto no mesmo dia com a motoFÁCIL Brasil. Ligue ou chame no WhatsApp: 0800 591 5641." />
<meta property="og:title" content="motoFÁCIL Brasil — Aluguel de Motos em Serra, ES" />
<meta property="og:description" content="Aluguel de moto rápido, simples e sem burocracia em Serra-ES. Saia de moto no mesmo dia." />
<meta property="og:type" content="website" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet" />
<script src="https://cdn.tailwindcss.com"></script>
<style>
  :root {
    --red: #D32F2F;
    --red-dark: #B71C1C;
    --red-light: #FFEBEE;
    --black: #111111;
    --off-white: #F7F7F5;
    --gray: #616161;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Barlow', sans-serif;
    background: #fff;
    color: var(--black);
    overflow-x: hidden;
  }

  h1, h2, h3, .condensed {
    font-family: 'Barlow Condensed', sans-serif;
  }

  /* ─── HEADER ─── */
  #header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 999;
    background: var(--black);
    border-bottom: 2px solid var(--red);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 26px;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.5px;
  }

  .logo span { color: var(--red); }

  nav a {
    color: #ccc;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-left: 28px;
    transition: color .2s;
  }

  nav a:hover { color: #fff; }

  .btn-header {
    background: var(--red);
    color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 10px 22px;
    border-radius: 6px;
    text-decoration: none;
    margin-left: 32px;
    transition: background .2s, transform .15s;
    white-space: nowrap;
  }

  .btn-header:hover {
    background: var(--red-dark);
    transform: translateY(-1px);
  }

  /* hamburger */
  #menu-toggle { display: none; background: none; border: none; cursor: pointer; padding: 8px; }
  #menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: #fff;
    margin: 5px 0;
    transition: .3s;
  }

  #mobile-nav {
    display: none;
    flex-direction: column;
    background: var(--black);
    padding: 16px 24px 24px;
    border-top: 1px solid #222;
  }

  #mobile-nav a {
    color: #ccc;
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
    padding: 12px 0;
    border-bottom: 1px solid #222;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  #mobile-nav a:last-child { border-bottom: none; }
  #mobile-nav a:hover { color: #fff; }

  .mobile-cta {
    background: var(--red);
    color: #fff !important;
    text-align: center;
    border-radius: 6px;
    padding: 14px !important;
    margin-top: 12px;
    border-bottom: none !important;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 18px !important;
  }

  /* ─── HERO ─── */
  #hero {
    margin-top: 64px;
    background: var(--black);
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 64px);
    height: calc(100vh - 64px);
    display: flex;
    align-items: center;
  }

  .hero-bg-accent {
    position: absolute;
    top: 0; right: 0;
    width: 45%;
    height: 100%;
    background: var(--red);
    clip-path: polygon(15% 0%, 100% 0%, 100% 100%, 0% 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: 1fr 1.8fr;
    gap: 0;
    align-items: center;
    width: 100%;
  }

  .hero-text {}

  .hero-badge {
    display: inline-block;
    background: var(--red);
    color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 4px;
    margin-bottom: 20px;
  }

  .hero-h1 {
    font-size: clamp(52px, 6.5vw, 88px);
    font-weight: 900;
    color: #fff;
    line-height: 0.92;
    text-transform: uppercase;
    letter-spacing: -1px;
    margin-bottom: 20px;
  }

  .hero-h1 em {
    color: var(--red);
    font-style: normal;
  }

  .hero-sub {
    color: #fff;
    font-size: 15px;
    line-height: 1.55;
    max-width: 480px;
    margin-bottom: 24px;
  }

  .hero-btns {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--red);
    color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 16px 32px;
    border-radius: 6px;
    text-decoration: none;
    transition: background .2s, transform .15s, box-shadow .2s;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .btn-primary:hover {
    background: var(--red-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(211,47,47,.35);
  }

  .btn-secondary {
    color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 16px 32px;
    border-radius: 6px;
    text-decoration: none;
    border: 2px solid rgba(255,255,255,.7);
    transition: border-color .2s, background .2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-secondary:hover {
    border-color: rgba(255,255,255,.6);
    background: rgba(255,255,255,.05);
  }

  .hero-img-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-placeholder {
    width: 100%;
    aspect-ratio: 16/9;
    background: rgba(255,255,255,.07);
    border: 1px dashed rgba(255,255,255,.2);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: rgba(255,255,255,.4);
    font-size: 13px;
    text-align: center;
    padding: 24px;
  }

  .hero-placeholder .ph-icon {
    font-size: 48px;
  }


  .sobre-img-real {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 4/5;
  }
  /* ─── STATS BAR ─── */
  .stats-bar {
    background: var(--red);
    padding: 0;
  }

  .stats-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .stat-item {
    padding: 24px 20px;
    text-align: center;
    border-right: 1px solid rgba(255,255,255,.2);
  }

  .stat-item:last-child { border-right: none; }

  .stat-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 36px;
    color: #fff;
    line-height: 1;
  }

  .stat-label {
    font-size: 12px;
    color: rgba(255,255,255,.75);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 4px;
  }

  /* ─── SECTION BASE ─── */
  section { padding: 96px 0; }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .section-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 900;
    color: var(--black);
    text-transform: uppercase;
    line-height: 1.05;
    margin-bottom: 16px;
  }

  .section-sub {
    color: var(--gray);
    font-size: 17px;
    line-height: 1.6;
    max-width: 560px;
    margin-bottom: 56px;
  }

  /* ─── SERVIÇOS ─── */
  #servicos { background: var(--off-white); }

  .servicos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .servico-card {
    background: #fff;
    border-radius: 12px;
    padding: 32px 28px;
    border: 1px solid #E8E8E5;
    transition: transform .2s, box-shadow .2s, border-color .2s;
  }

  .servico-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,.1);
    border-color: var(--red);
  }

  .card-icon {
    font-size: 36px;
    margin-bottom: 16px;
    display: block;
  }

  .card-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 22px;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 10px;
    letter-spacing: 0.3px;
  }

  .card-desc {
    color: var(--gray);
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .card-cta {
    color: var(--red);
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap .2s;
  }

  .card-cta:hover { gap: 10px; }

  /* ─── COMO FUNCIONA ─── */
  #como-funciona { background: #fff; }

  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }

  .steps::before {
    content: '';
    position: absolute;
    top: 32px;
    left: 12.5%;
    width: 75%;
    height: 2px;
    background: linear-gradient(90deg, var(--red), #E57373);
    z-index: 0;
  }

  .step {
    text-align: center;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }

  .step-num {
    width: 64px;
    height: 64px;
    background: var(--red);
    color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    border: 4px solid #fff;
    box-shadow: 0 0 0 2px var(--red);
  }

  .step-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 18px;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 8px;
  }

  .step-desc {
    color: var(--gray);
    font-size: 14px;
    line-height: 1.6;
  }

  /* ─── SOBRE ─── */
  #sobre { background: var(--black); }

  .sobre-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .sobre-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 12px;
  }

  .sobre-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(32px, 4vw, 48px);
    color: #fff;
    text-transform: uppercase;
    line-height: 1.05;
    margin-bottom: 24px;
  }

  .sobre-title em {
    color: var(--red);
    font-style: normal;
  }

  .sobre-p {
    color: #aaa;
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .selos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 40px;
  }

  .selo {
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 10px;
    padding: 20px 16px;
    text-align: center;
  }

  .selo-icon { font-size: 28px; margin-bottom: 8px; display: block; }

  .selo-text {
    color: #ddd;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1.4;
  }

  .sobre-img {
    background: rgba(255,255,255,.05);
    border: 1px dashed rgba(255,255,255,.15);
    border-radius: 12px;
    aspect-ratio: 4/3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: rgba(255,255,255,.3);
    font-size: 13px;
    text-align: center;
    padding: 24px;
  }

  /* ─── FAQ ─── */
  #faq { background: var(--off-white); }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
  }

  .faq-list { display: flex; flex-direction: column; gap: 8px; }

  details {
    background: #fff;
    border-radius: 10px;
    border: 1px solid #E8E8E5;
    overflow: hidden;
    transition: border-color .2s;
  }

  details[open] { border-color: var(--red); }

  summary {
    padding: 20px 24px;
    cursor: pointer;
    font-weight: 600;
    font-size: 16px;
    color: var(--black);
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    user-select: none;
  }

  summary::-webkit-details-marker { display: none; }

  .faq-arrow {
    font-size: 20px;
    color: var(--red);
    flex-shrink: 0;
    transition: transform .2s;
  }

  details[open] .faq-arrow { transform: rotate(45deg); }

  .faq-body {
    padding: 0 24px 20px;
    color: var(--gray);
    font-size: 15px;
    line-height: 1.7;
    border-top: 1px solid #F0F0EE;
    padding-top: 16px;
  }

  .faq-aside {
    background: var(--red);
    border-radius: 16px;
    padding: 40px 36px;
    color: #fff;
    text-align: center;
    position: sticky;
    top: 88px;
  }

  .faq-aside-icon { font-size: 48px; margin-bottom: 16px; display: block; }

  .faq-aside h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 28px;
    text-transform: uppercase;
    margin-bottom: 12px;
    color: #fff;
  }

  .faq-aside p {
    font-size: 15px;
    color: rgba(255,255,255,.8);
    line-height: 1.6;
    margin-bottom: 28px;
  }

  .btn-white {
    background: #fff;
    color: var(--red);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 18px;
    text-transform: uppercase;
    padding: 14px 28px;
    border-radius: 6px;
    text-decoration: none;
    display: inline-block;
    transition: transform .15s, box-shadow .2s;
  }

  .btn-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,.15);
  }

  /* ─── CONTATO ─── */
  #contato { background: var(--black); padding: 96px 0 0; }

  .cta-banner {
    text-align: center;
    padding: 0 24px 80px;
  }

  .cta-banner h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(36px, 6vw, 72px);
    color: #fff;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 16px;
  }

  .cta-banner h2 em {
    color: var(--red);
    font-style: normal;
  }

  .cta-banner p {
    color: #aaa;
    font-size: 18px;
    margin-bottom: 40px;
  }

  .contato-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(255,255,255,.1);
  }

  .contato-item {
    padding: 40px 32px;
    border-right: 1px solid rgba(255,255,255,.1);
  }

  .contato-item:last-child { border-right: none; }

  .contato-item-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 12px;
  }

  .contato-item-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 20px;
    color: #fff;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .contato-item p, .contato-item a {
    color: #aaa;
    font-size: 15px;
    line-height: 1.7;
    text-decoration: none;
  }

  .contato-item a:hover { color: #fff; }

  /* ─── FOOTER ─── */
  footer {
    background: #0a0a0a;
    border-top: 1px solid #1a1a1a;
    padding: 40px 24px;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-logo {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 22px;
    color: #fff;
  }

  .footer-logo span { color: var(--red); }

  .footer-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: #666;
    text-decoration: none;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color .2s;
  }

  .footer-links a:hover { color: #fff; }

  .footer-copy {
    color: #444;
    font-size: 13px;
    width: 100%;
    text-align: center;
    padding-top: 24px;
    border-top: 1px solid #1a1a1a;
    margin-top: 16px;
  }

  /* ─── FADE-IN ─── */
  .fade-in {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .5s ease, transform .5s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: none;
  }

  /* ─── RESPONSIVO ─── */
  @media (max-width: 1024px) {
    .servicos-grid { grid-template-columns: repeat(2, 1fr); }
    .steps { grid-template-columns: repeat(2, 1fr); gap: 32px; }
    .steps::before { display: none; }
    .faq-grid { grid-template-columns: 1fr; }
    .faq-aside { position: static; }
    .contato-grid { grid-template-columns: 1fr; }
    .contato-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,.1); }
    .contato-item:last-child { border-bottom: none; }
  }

  @media (max-width: 768px) {
    nav, .btn-header { display: none; }
    #menu-toggle { display: block; }
    .hero-inner { grid-template-columns: 1fr; padding: 32px 24px; }
    .hero-img-wrapper { display: none; }
    #hero { height: calc(100vh - 64px); min-height: calc(100vh - 64px); }
    .hero-bg-accent { width: 100%; clip-path: none; opacity: 0.08; }
    .hero-h1 { font-size: 46px; }
    .sobre-grid { grid-template-columns: 1fr; gap: 40px; }
    .selos { grid-template-columns: 1fr; }
    .stats-inner { grid-template-columns: repeat(2, 1fr); }
    .stat-item:nth-child(2) { border-right: none; }
    .servicos-grid { grid-template-columns: 1fr; }
    .steps { grid-template-columns: 1fr; }
    section { padding: 64px 0; }
  }

  @media (max-width: 480px) {
    .hero-btns { flex-direction: column; }
    .btn-primary, .btn-secondary { justify-content: center; }
    .hero-h1 { font-size: 40px; }
  }

  /* whatsapp float */
  .wa-float {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 998;
    background: #25D366;
    color: #fff;
    border-radius: 50%;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(0,0,0,.25);
    text-decoration: none;
    font-size: 28px;
    transition: transform .2s, box-shadow .2s;
  }

  .wa-float:hover {
    transform: scale(1.1);
    box-shadow: 0 8px 32px rgba(0,0,0,.35);
  }
</style>

